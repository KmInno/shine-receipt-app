<title>Create Receipt</title>

<style>

body{
    font-family: Arial;
    background:#f4f4f4;
}

.container{
    max-width:700px;
    margin:auto;
    background:white;
    padding:20px;
    border-radius:6px;
}

h2{
    text-align:center;
}

label{
    font-weight:bold;
    display:block;
    margin-top:10px;
}

input,select,button{
    width:100%;
    padding:8px;
    margin-top:5px;
}

.services-table{
    width:100%;
    border-collapse:collapse;
    margin-top:10px;
}

.services-table th,
.services-table td{
    border:1px solid #ccc;
    padding:6px;
}

.add-btn{
    margin-top:10px;
    background:#007bff;
    color:white;
    border:none;
}

.submit-btn{
    margin-top:20px;
    background:#28a745;
    color:white;
    border:none;
}

</style>


<div class="container">

<h2>Create Receipt</h2>

<form id="receiptForm" action="/receipt/create" method="POST">

<!-- <label>Receipt Name</label>
<input type="text" name="receipt_name">

<label>Patient Number</label>
<input type="text" name="patient_number"> -->

<label>Patient Name</label>
<input type="text" name="patient_name" required>

<label>Phone</label>
<input type="text" name="patient_phone" required>

<label>Address</label>
<input type="text" name="patient_address">


<h3>Services</h3>

<table class="services-table">

<thead>

<tr>
<th>Service</th>
<th>Unit Price</th>
<th>Qty</th>
<!-- <th>Discount</th> -->
<th>Amount</th>
<th>Remove</th>
</tr>

</thead>

<tbody id="servicesContainer"></tbody>

</table>

<button type="button" class="add-btn" onclick="addService()">Add Service</button>


<input type="hidden" id="service" name="service">

<label>Total (UGX)</label>
<input type="number" id="total" name="total" readonly>


<label>Mode of Payment</label>

<select name="mode_of_payment" required>

<option value="">Select</option>
<option value="cash">Cash</option>
<option value="mobile money">Mobile Money</option>
<option value="visa">Visa</option>

</select>


<label>Amount Paid (UGX)</label>
<input type="number" id="amount_paid" name="amount_paid" value="0">

<input type="hidden" id="balance" name="balance">


<button type="submit" class="submit-btn">Create Receipt</button>

</form>

</div>

<script>

function addService(){
const table = document.getElementById("servicesContainer");

const row = document.createElement("tr");

row.innerHTML = `

<td><input type="text" class="service-name" required></td>
<td><input type="number" class="price" value="0"></td>
<td><input type="number" class="qty" value="1"></td>

<!-- <td><input type="number" class="discount" value="0"></td> -->

<td><input type="number" class="amount" value="0" readonly></td>

<td><button type="button" onclick="this.closest('tr').remove();calculateTotal()">X</button></td>

`;

table.appendChild(row);

row.querySelectorAll("input").forEach(i => {
i.addEventListener("input", calculateTotal);
});

calculateTotal();
}



function calculateTotal(){

let total = 0;

document.querySelectorAll("#servicesContainer tr").forEach(row => {

const price = parseFloat(row.querySelector(".price").value) || 0;
const qty = parseFloat(row.querySelector(".qty").value) || 1;

const amount = (price * qty);
row.querySelector(".amount").value = amount;

total += amount;

});

document.getElementById("total").value = total;

calculateBalance();

}



function calculateBalance(){

const total = parseFloat(document.getElementById("total").value) || 0;

const paid = parseFloat(document.getElementById("amount_paid").value) || 0;

document.getElementById("balance").value = total - paid;

}

document.getElementById("amount_paid").addEventListener("input", calculateBalance);



document.getElementById("receiptForm").addEventListener("submit", function(){

const services = [];

document.querySelectorAll("#servicesContainer tr").forEach(row => {

services.push({

name: row.querySelector(".service-name").value,

qty: row.querySelector(".qty").value,

amount: row.querySelector(".amount").value

});

});

document.getElementById("service").value = JSON.stringify(services);

});


window.onload = function(){

addService();

}

</script>
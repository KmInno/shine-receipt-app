<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Invoice</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f4f4f4;
        }

        .container {
            max-width: 600px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        h2 {
            color: #333;
            text-align: center;
        }

        label {
            font-weight: bold;
            display: block;
            margin-top: 15px;
            color: #555;
        }

        input,
        textarea,
        select,
        button {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border: 1px solid #ddd;
            border-radius: 4px;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        textarea {
            resize: vertical;
            min-height: 60px;
        }

        button {
            background-color: #007bff;
            color: white;
            font-weight: bold;
            cursor: pointer;
            border: none;
            margin-top: 20px;
        }

        button:hover {
            background-color: #0056b3;
        }

        .form-section {
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 2px solid #eee;
        }

        .form-section:last-of-type {
            border-bottom: none;
        }

        .section-title {
            font-size: 16px;
            font-weight: bold;
            color: #007bff;
            margin-bottom: 10px;
        }

        .item-display {
            background: #f9f9f9;
            padding: 15px;
            margin-top: 10px;
            border-radius: 4px;
            border-left: 4px solid #007bff;
        }

        .read-only {
            background-color: #e9ecef;
            color: #666;
            cursor: not-allowed;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Edit Invoice</h2>
        <form action="/invoices/edit/<%= invoice.id %>" method="POST">
            
            <!-- Invoice Number (Read-only) -->
            <div class="form-section">
                <label for="invoice_number">Invoice Number:</label>
                <input type="text" id="invoice_number" value="<%= invoice.invoice_number %>" readonly class="read-only" />
            </div>

            <!-- Client Information -->
            <div class="form-section">
                <div class="section-title">Client Information</div>
                
                <label for="client_name">Client Name:</label>
                <input type="text" id="client_name" name="client_name" value="<%= invoice.client_name %>" required />

                <label for="client_address">Client Address:</label>
                <textarea id="client_address" name="client_address"><%= invoice.client_address || '' %></textarea>

                <label for="client_tel">Client Phone:</label>
                <input type="text" id="client_tel" name="client_tel" value="<%= invoice.client_tel %>" required />
            </div>

            <!-- Invoice Information -->
            <div class="form-section">
                <div class="section-title">Invoice Information</div>
                
                <label for="invoice_date">Invoice Date:</label>
                <input type="date" id="invoice_date" name="invoice_date" value="<%= invoice.invoice_date.toISOString().split('T')[0] %>" required />

                <!-- LPO field removed -->

                <label for="status">Status:</label>
                <select id="status" name="status" required>
                    <option value="draft" <%= invoice.status === 'draft' ? 'selected' : '' %>>Draft</option>
                    <option value="sent" <%= invoice.status === 'sent' ? 'selected' : '' %>>Sent</option>
                    <option value="paid" <%= invoice.status === 'paid' ? 'selected' : '' %>>Paid</option>
                    <option value="cancelled" <%= invoice.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                </select>
            </div>

            <!-- Items Summary -->
            <div class="form-section">
                <div class="section-title">Invoice Items</div>
                
                <div id="itemsContainer">
                    <% invoice.items.forEach((item, index) => { %>
                        <div class="item-display">
                            <strong><%= item.item_name %></strong><br>
                            Qty: <%= item.qty %> × UGX <%= parseFloat(item.unit_price).toLocaleString('en-US') %> = UGX <%= parseFloat(item.amount).toLocaleString('en-US') %>
                        </div>
                    <% }) %>
                </div>

                <p style="color: #999; font-size: 12px; margin-top: 10px;">
                    <em>To modify items, create a new invoice or contact support.</em>
                </p>
            </div>

            <!-- Total -->
            <div class="form-section">
                <label for="total">Total Amount (UGX):</label>
                <input type="number" id="total" name="total" value="<%= invoice.total %>" step="0.01" readonly class="read-only" />
            </div>

            <button type="submit">Update Invoice</button>
        </form>
    </div>
</body>
</html>

<%- include('partials/footer') %>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .hidden {
            display: none;
        }

        .action-buttons {
            display: flex;
            gap: 5px;
        }

        .status-badge {
            padding: 5px 10px;
            border-radius: 4px;
            font-weight: bold;
            font-size: 12px;
        }

        .status-draft {
            background-color: #ffc107;
            color: black;
        }

        .status-sent {
            background-color: #17a2b8;
            color: white;
        }

        .status-paid {
            background-color: #28a745;
            color: white;
        }

        .status-cancelled {
            background-color: #dc3545;
            color: white;
        }

        .status-dropdown {
            padding: 5px 8px;
            border-radius: 4px;
            border: none;
            font-weight: bold;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .status-dropdown.draft {
            background-color: #ffc107;
            color: black;
        }

        .status-dropdown.sent {
            background-color: #17a2b8;
            color: white;
        }

        .status-dropdown.paid {
            background-color: #28a745;
            color: white;
        }

        .status-dropdown.cancelled {
            background-color: #dc3545;
            color: white;
        }

        .status-dropdown:hover {
            opacity: 0.8;
        }

        .status-updating {
            opacity: 0.6;
            pointer-events: none;
        }
    </style>
</head>

<body>
    <div class="table">
        <div class="table-specs">

            <h2>
                <%= title %>
            </h2>
            <a href="/invoices/new"
                style="margin-bottom: 15px; padding: 10px 20px; background-color: #ef4444; color: white; text-decoration: none; border-radius: 4px; display: inline-block;">+
                New Invoice</a>

            <input type="text" id="filter" placeholder="Search Invoice Number or Client....">
            <table>
                <thead>
                    <tr>
                        <th>Invoice No</th>
                        <th>Date</th>
                        <th>Client Name</th>
                        <th>Phone</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% invoices.forEach(invoice=> { %>
                        <tr class="item-list">
                            <td><strong>
                                    <%= invoice.invoice_number %>
                                </strong></td>
                            <td>
                                <%= new Date(invoice.invoice_date).toLocaleDateString('en-GB') %>
                            </td>
                            <td class="names"><a href="/invoices/<%= invoice.id %>">
                                    <%= invoice.client_name %>
                                </a></td>
                            <td>
                                <%= invoice.client_tel %>
                            </td>
                            <td>UGX <%= parseFloat(invoice.total).toLocaleString('en-US') %>
                            </td>
                            <td>
                                <% if (user && user.usertype==='admin') { %>
                                    <select class="status-dropdown <%= invoice.status %>" data-invoice-id="<%= invoice.id %>" onchange="updateInvoiceStatus(this)">
                                        <option value="draft" <%= invoice.status === 'draft' ? 'selected' : '' %>>Draft</option>
                                        <option value="sent" <%= invoice.status === 'sent' ? 'selected' : '' %>>Sent</option>
                                        <option value="paid" <%= invoice.status === 'paid' ? 'selected' : '' %>>Paid</option>
                                        <option value="cancelled" <%= invoice.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                    </select>
                                <% } else { %>
                                    <span class="status-badge status-<%= invoice.status %>">
                                        <%= invoice.status.charAt(0).toUpperCase() + invoice.status.slice(1) %>
                                    </span>
                                <% } %>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href="/invoices/<%= invoice.id %>" style="color: #007bff;">View</a>
                                    <% if (user && user.usertype==='admin' ) { %>
                                        <a href="/invoices/edit/<%= invoice.id %>" style="color: #28a745;">Edit</a>
                                        <button onclick="deleteInvoice('<%= invoice.id %>')"
                                            style="color: white; background-color: #dc3545; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">Delete</button>
                                        <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        document.getElementById('filter').addEventListener('input', function () {
            const filterValue = this.value.toLowerCase();
            const rows = document.querySelectorAll("tbody tr");

            rows.forEach(row => {
                const cells = row.querySelectorAll("td");
                let match = false;
                cells.forEach(cell => {
                    if (cell.textContent.toLowerCase().includes(filterValue)) {
                        match = true;
                    }
                });
                row.style.display = match ? "" : "none";
            });
        });

        async function updateInvoiceStatus(selectElement) {
            const invoiceId = selectElement.dataset.invoiceId;
            const newStatus = selectElement.value;
            
            selectElement.classList.add('status-updating');

            try {
                const response = await fetch(`/invoices/${invoiceId}/status`, {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ status: newStatus })
                });

                const result = await response.json();

                if (response.ok) {
                    // Update the dropdown styling based on new status
                    selectElement.classList.remove('draft', 'sent', 'paid', 'cancelled');
                    selectElement.classList.add(newStatus);
                    alert('Invoice status updated successfully');
                } else {
                    alert(result.message || 'Error updating invoice status');
                    // Revert the select to previous value on error
                    location.reload();
                }
            } catch (error) {
                console.error('Error updating invoice status:', error);
                alert('Error updating invoice status');
                location.reload();
            } finally {
                selectElement.classList.remove('status-updating');
            }
        }

        async function deleteInvoice(invoiceId) {
            if (confirm("Are you sure you want to delete this invoice?")) {
                try {
                    const response = await fetch(`/invoices/delete/${invoiceId}`, {
                        method: 'DELETE'
                    });
                    const result = await response.json();
                    if (response.ok) {
                        alert(result.message);
                        location.reload();
                    } else {
                        alert(result.message || "Error deleting invoice");
                    }
                } catch (error) {
                    alert("Error deleting invoice");
                }
            }
        }
    </script>
</body>

</html>

<%- include('partials/footer') %>